{
  "expo": {
    "name": "Supli AI",
    "slug": "supli-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F2EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.supliai",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F2EC"
      },
      "package": "com.supliai",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "supliai"
  }
}
